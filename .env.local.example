# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# Resend (emails)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=GHL Titan <onboarding@resend.dev>
EMAIL_ADMIN=tu-email@ejemplo.com
# Token del cron que procesa los emails programados de automatizaciones
CRON_SECRET=cambia-esto-por-un-token-secreto
